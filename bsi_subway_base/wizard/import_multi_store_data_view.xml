<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="bsi_import_multi_stores_data_entry_form_view" model="ir.ui.view">
        <field name="name">bsi.import.multi.stores.data.entry.wizard.form</field>
        <field name="model">bsi.import.multi.stores.data.entry.wizard</field>
        <field name="arch" type="xml">
            <form string="Update Product">
                <sheet>
                    <group>
                        <field name="file"/>
                    </group>
                    <footer>
                        <button string="Cancel" class="btn-default" special="cancel"/>
                        <button string="Import Multi Stores Data" type="object" name="import_multi_stores_data_button" class="btn-default"/>
                    </footer>
                </sheet>
            </form>	   		
        </field>
    </record>

    <record id="action_bsi_import_multi_stores_data_entry_form_view" model="ir.actions.act_window">
        <field name="name">Import Multi Stores Entry</field>
        <field name="res_model">bsi.import.multi.stores.data.entry.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="bsi_import_multi_stores_data_entry_form_view"/>	
    </record>

    <menuitem id="menu_action_bsi_import_multi_stores_data_entry_form_view"
        parent="bsi_subway_base.config_import_update_submenu"
        name="Import Multi Stores Entry"
        action="action_bsi_import_multi_stores_data_entry_form_view"
        sequence="5"/>

</odoo>
