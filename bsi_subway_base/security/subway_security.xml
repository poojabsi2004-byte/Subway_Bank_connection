    <record id="allowed_attendances" model="ir.rule">
        <field name="name">Allowed Attendances (Employee, SM, DM)</field>
        <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
        <field name="domain_force">[('employee_id', 'in', user.domain_employee_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('bsi_subway_base.store_employee')), 
                                    (4, ref('bsi_subway_base.store_manager')), 
                                    (4, ref('bsi_subway_base.store_dm'))]"/>
    </record>

    <record id="allowed_attendances_owner_and_admin" model="ir.rule">
        <field name="name">Allowed Attendances Owner and Admin</field>
        <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('bsi_subway_base.store_admin')), (4, ref('bsi_subway_base.store_owner'))]"/>
    </record>

