<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Subway Store Groups and Record Rules -->
    <record id="bsi_subway_management_store" model="ir.module.category">
        <field name="name">Subway Access</field>
        <field name="sequence" eval="20"/>
        <field name="description">User access levels for Subway Management</field>
    </record>

    <record id="store_employee" model="res.groups">
        <field name="name">Store Employee</field>
        <field name="category_id" ref="bsi_subway_base.bsi_subway_management_store"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="store_manager" model="res.groups">
        <field name="name">Store Manager</field>
        <field name="category_id" ref="bsi_subway_base.bsi_subway_management_store"/>
        <field name="implied_ids" eval="[(4, ref('bsi_subway_base.store_employee'))]"/>
    </record>

    <record id="store_dm" model="res.groups">
        <field name="name">Store District Manager</field>
        <field name="category_id" ref="bsi_subway_base.bsi_subway_management_store"/>
        <field name="implied_ids" eval="[(4, ref('bsi_subway_base.store_manager'))]"/>
    </record>

    <record id="store_owner" model="res.groups">
        <field name="name">Store Owner</field>
        <field name="category_id" ref="bsi_subway_base.bsi_subway_management_store"/>
        <field name="implied_ids" eval="[(4, ref('bsi_subway_base.store_dm'))]"/>
    </record>

    <record id="store_admin" model="res.groups">
        <field name="name">Botspot Team</field>
        <field name="category_id" ref="bsi_subway_base.bsi_subway_management_store"/>
        <field name="implied_ids" eval="[(4, ref('bsi_subway_base.store_owner'))]"/>
    </record>

    <!-- GS - FEB6 Record Rule for Allowed Schedulings -->
    <record id="allowed_store_schedulings_managers" model="ir.rule">
        <field name="name">Allowed Store Schedulings Managers</field>
        <field name="model_id" ref="bsi_subway_base.model_store_scheduling"/>
        <field name="domain_force">[('store_id.id','in', user.employee_id.store_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('bsi_subway_base.store_dm')), (4, ref('bsi_subway_base.store_manager'))]"/>
    </record>

    <record id="allowed_store_schedulings_owner" model="ir.rule">
        <field name="name">Allowed Store Schedulings Owner and Admin</field>
        <field name="model_id" ref="bsi_subway_base.model_store_scheduling"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('bsi_subway_base.store_admin')), (4, ref('bsi_subway_base.store_owner'))]"/>
    </record>


    <record id="allowed_employees" model="ir.rule">
        <field name="name">Allowed Employees</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="domain_force">['|', ('id','=', user.employee_id.id), '|', ('user_ids','=', user.id), "&amp;", ('user_ids', '=', False), ('create_uid', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('bsi_subway_base.store_employee')), (4, ref('bsi_subway_base.store_manager')), (4, ref('bsi_subway_base.store_dm'))]"/>
    </record>

    <record id="allowed_employees_owner_and_admin" model="ir.rule">
        <field name="name">Allowed Employees Owner and Admin</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="domain_force">[]</field>
        <field name="groups" eval="[(4, ref('bsi_subway_base.store_admin')), (4, ref('bsi_subway_base.store_owner'))]"/>
    </record>

