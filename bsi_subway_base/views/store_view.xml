<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="store_store_form_view" model="ir.ui.view">
        <field name="name">store.store.form</field>
        <field name="model">store.store</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Stores">
                            <field name="name" />
                            <field name="is_exclude_store" invisible='1'/>
                            <field name="store_number" options="{'format': 0}" widget="char"/>
                            <field name="name_with_number"/>
                        </group>
                        <group string="Other">
                            <field name="geo_location_id" readonly='1'/>
                            <field name="currency_id"/>
                            <field name="total_hourly_wage" widget="monetary" groups="bsi_subway_base.store_owner,bsi_subway_base.store_admin"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <group string="Members">
                        <field name="employee_ids" widget="many2many_tags"/>
                        <field name="store_manager_ids" widget="many2many_tags"/>
                        <field name="district_manager_ids" widget="many2many_tags"/>
                    </group>
                    <group>
                        <button name="update_employee_attendance" type="object" string="Update User's Employees" class="btn-primary" groups="bsi_subway_base.store_admin"/>
                    </group>
                    <notebook>
                        <page string='Store Data'>
                            <field name="store_line_ids">
                                <list create="false">
                                    <field name="combination_rec_name"/>
                                    <field name="week_starting_date"/>
                                    <field name="week_ending_date"/>
                                    <field name="total_scheduled_hours" widget="float_time"/>
                                    <field name="total_worked_hours" widget="float_time"/>
                                    <field name="state" widget="badge"/>
                                    <button name="view_store_scheduling_record" type="object" string=" " class="fa fa-info-circle" help="To check the Scheduled Week"/>
                                </list>
                            </field>
                        </page>

                        <page string='Cash Deposit Details' groups="bsi_subway_base.store_owner,bsi_subway_base.store_admin">
                            <group>
                                <group>
                                    <field name="recipient_user_ids" widget="many2many_tags"/>
                                </group>
                                <group>
                                    <field name="wednesday"/>
                                    <field name="thursday"/>
                                    <field name="friday"/>
                                    <field name="saturday"/>
                                    <field name="sunday"/>
                                    <field name="monday"/>
                                    <field name="tuesday"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <!-- <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div> -->
                <chatter/>
            </form>
        </field>
    </record>

    <record id="store_store_list_view" model="ir.ui.view">
        <field name="name">store.store.list</field>
        <field name="model">store.store</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="store_number" options="{'format': 0}" widget="char"/>
                <field name="geo_location_id"/>
                <field name="store_manager_ids" widget="many2many_tags"/>
                <field name="district_manager_ids" widget="many2many_tags"/>
                <field name="total_hourly_wage" groups="bsi_subway_base.store_owner,bsi_subway_base.store_admin"/> 
            </list>
        </field>
    </record>

    <record id="store_store_graph_view" model="ir.ui.view">
        <field name="name">store.store.graph</field>
        <field name="model">store.store</field>
        <field name="arch" type="xml">
            <graph string="Store" sample="1">
                <field name="name"/>
                <field name="total_hourly_wage" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="store_store_pivot_view" model="ir.ui.view">
        <field name="name">store.store.pivot</field>
        <field name="model">store.store</field>
        <field name="arch" type="xml">
            <pivot string="Store" sample="1">
                <field name="name" type="row"/>
                <field name="total_hourly_wage" type="measure" groups="bsi_subway_base.store_owner,bsi_subway_base.store_admin"/>
            </pivot>
        </field>
    </record>

    <record id="store_store_search_view" model="ir.ui.view">
        <field name="name">store.store.search.view</field>
        <field name="model">store.store</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="store_number" widget="char"/>
                <separator/>
                <filter name="unactive" string="Archived" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <record id="action_store_store_view" model="ir.actions.act_window">
        <field name="name">Stores</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">store.store</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'list', 'view_id': ref('bsi_subway_base.store_store_list_view')}),
        (0, 0, {'view_mode': 'form', 'view_id': ref('bsi_subway_base.store_store_form_view')})]"/>
    </record>

</odoo>
