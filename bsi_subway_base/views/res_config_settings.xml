<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_inherit_from_for_week_auto" model="ir.ui.view">
        <field name="name">res.config.settings.form.view.inherited</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div//block//setting[@id='inter_company']" position="after">
                <div class="col-12 col-lg-6 o_setting_box" style="margin-left:40px;">
                    <div class="row mb-2">
                        <div class="col-12">
                            <label for="week_automation_count">Week Automation Count</label>
                            <field name="week_automation_count"/>
                        </div>
                        <div class="col-12">
                            <label for="post_message_in_emp">Post Log Msgs in Employee?</label>
                            <field name="post_message_in_emp"/>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>