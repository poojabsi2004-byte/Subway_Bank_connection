<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="bsi_store_actual_hours_list_view" model="ir.ui.view">
		<field name="name">store.actual.hours.list.view</field>
		<field name="model">store.actual.hours</field>
		<field name="arch" type="xml">
			<list editable="bottom">
				<field name="week_actual_sale"/>
				<field name="week_actual_hours" widget="float_time"/>
			</list>
		</field>
	</record>

	<record id="action_store_actual_hours_view" model="ir.actions.act_window">
		<field name="name">Store Allowed hours management</field>
		<field name="type">ir.actions.act_window</field>
		<field name="res_model">store.actual.hours</field>
		<field name="view_mode">list</field>
	</record>

</odoo>
