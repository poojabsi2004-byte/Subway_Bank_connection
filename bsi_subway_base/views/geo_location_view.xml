<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="bsi_geo_location_form_view_inherit" model="ir.ui.view">
		<field name="name">bsi.geo.location.form.view.inherit</field>
		<field name="model">emp.geo_location</field>
		<field name="inherit_id" ref="bsi_geo_attendance.view_emp_geo_form"/>
		<field name="arch" type="xml">
			<xpath expr="//field[@name='name']" position="after">
				<field name="store_id" readonly='1'/>
				<field name="store_number" readonly='1' widget="char"/>
			</xpath>
		</field>
	</record>

	<record id="bsi_geo_location_list_view_inherit" model="ir.ui.view">
		<field name="name">bsi.geo.location.list.view.inherit</field>
		<field name="model">emp.geo_location</field>
		<field name="inherit_id" ref="bsi_geo_attendance.view_empl_geo_list"/>
		<field name="arch" type="xml">
			<xpath expr="//field[@name='name']" position="after">
				<field name="store_id"/>
				<field name="store_number" widget="char"/>
			</xpath>
		</field>
	</record>
	
</odoo>
