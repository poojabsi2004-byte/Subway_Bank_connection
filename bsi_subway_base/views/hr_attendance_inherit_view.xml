<?xml version="1.0" encoding="utf-8"?>
<odoo>

	<!-- RM - 29 Aug [ADD] Need to add new filter/group of store into attendance list view -->
	<record id="bsi_hr_attendance_list_view_inherit" model="ir.ui.view">
		<field name="name">hr.attendance.list.view.inherit</field>
		<field name="model">hr.attendance</field>
		<field name="inherit_id" ref="hr_attendance.view_attendance_tree"/>
		<field name="arch" type="xml">

		<xpath expr="//field[@name='overtime_status']" position="attributes">
	            <attribute name="groups">bsi_subway_base.store_admin</attribute>
	        </xpath>

	        <xpath expr="//field[@name='in_mode']" position="attributes">
	            <attribute name="groups">bsi_subway_base.store_admin</attribute>
	        </xpath>

	        <xpath expr="//field[@name='out_mode']" position="attributes">
	            <attribute name="groups">bsi_subway_base.store_admin</attribute>
	        </xpath>

	        <xpath expr="//field[@name='in_latitude']" position="attributes">
	            <attribute name="groups">bsi_subway_base.store_admin</attribute>
	        </xpath>

	        <xpath expr="//field[@name='in_longitude']" position="attributes">
	            <attribute name="groups">bsi_subway_base.store_admin</attribute>
	        </xpath>

	        <xpath expr="//field[@name='out_latitude']" position="attributes">
	            <attribute name="groups">bsi_subway_base.store_admin</attribute>
	        </xpath>

	        <xpath expr="//field[@name='out_longitude']" position="attributes">
	            <attribute name="groups">bsi_subway_base.store_admin</attribute>
	        </xpath>

	        <xpath expr="//field[@name='in_city']" position="attributes">
	            <attribute name="groups">bsi_subway_base.store_admin</attribute>
	        </xpath>

	        <xpath expr="//field[@name='out_city']" position="attributes">
	            <attribute name="groups">bsi_subway_base.store_admin</attribute>
	        </xpath>

	        <xpath expr="//field[@name='in_country_name']" position="attributes">
	            <attribute name="groups">bsi_subway_base.store_admin</attribute>
	        </xpath>

	        <xpath expr="//field[@name='out_country_name']" position="attributes">
	            <attribute name="groups">bsi_subway_base.store_admin</attribute>
	        </xpath>

	        <xpath expr="//field[@name='create_uid']" position="attributes">
	            <attribute name="groups">bsi_subway_base.store_admin</attribute>
	        </xpath>

	        <xpath expr="//field[@name='write_uid']" position="attributes">
	            <attribute name="groups">bsi_subway_base.store_admin</attribute>
	        </xpath>

	        <xpath expr="//field[@name='write_date']" position="attributes">
	            <attribute name="groups">bsi_subway_base.store_admin</attribute>
	        </xpath>
			<xpath expr="//field[@name='employee_id']" position="after">
				<field name="store_id" />
			</xpath>
			<xpath expr="//field[@name='check_out']" position="after">
				<field name="checkout_store_id" />
			</xpath>

			<!-- RM - [Sep17 - 2025] Extra Fields remove list view = START-->
			<xpath expr="//field[@name='overtime_hours']" position="attributes">
	            <attribute name="column_invisible">1</attribute>
	        </xpath>
	        <xpath expr="//field[@name='validated_overtime_hours']" position="attributes">
	            <attribute name="column_invisible">1</attribute>
	        </xpath>
	        <!-- RM - [Sep17 - 2025] Extra Fields remove list view = END -->

			<xpath expr="//list" position="attributes">
				<attribute name="decoration-danger">checkout_store_id and store_id != checkout_store_id</attribute>
			</xpath>
		</field>
	</record>

	<record id="bsi_hr_attendance_new_list_view" model="ir.ui.view">
        <field name="name">hr.attendance.new.list.view</field>
        <field name="model">hr.attendance</field>
        <field name="arch" type="xml">
            <list editable='top' >
                <field name="employee_id" readonly="1"/>
                <field name="store_id" readonly="1"/>
                <field name="check_in" readonly="1"/>
                <field name="check_out" readonly="1"/>
                <field name="checkout_store_id" readonly="1"/>
                <field name="worked_hours" readonly="1"/>
                <field name="previous_check_in" groups="bsi_subway_base.store_dm" readonly="1"/>
				<field name="previous_check_out" groups="bsi_subway_base.store_dm" readonly="1"/>
				<field name="modified_by_user_id" groups="bsi_subway_base.store_dm" readonly="1"/>
				<field name="adjustment_difference" widget="float_time" groups="bsi_subway_base.store_dm" />

				<!-- RM - 18 SEP [ADD] Click the button and the attendance form view will open -->
				<button name="open_attendance_form_view"
					type="object"
					class="btn-primary"
					string="Click here to Edit"/>
            </list>
        </field>
    </record>

	<!-- RM - 18 SEP [ADD] Click the button and the attendance form view will open -->
	<record id="bsi_hr_attendance_form_view_inherit" model="ir.ui.view">
		<field name="name">hr.attendance.form.view.inherit</field>
		<field name="model">hr.attendance</field>
		<field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
		<field name="arch" type="xml">
			<field name="employee_id" position="attributes">
				<attribute name="readonly">is_store_readonly</attribute>
			</field>
			<field name="check_in" position="attributes">
				<attribute name="readonly">is_store_readonly</attribute>
			</field>
			<field name="check_out" position="attributes">
				<attribute name="readonly">is_store_readonly</attribute>
			</field>
			<field name="worked_hours" position="attributes">
				<attribute name="invisible">1</attribute>
			</field>
			<field name="validated_overtime_hours" position="attributes">
				<attribute name="invisible">1</attribute>
			</field>

			<xpath expr="//field[@name='employee_id']" position="after">
				<field name="is_store_readonly" invisible="1"/>
				<field name="store_id" readonly="is_store_readonly"/>
			</xpath>

			<xpath expr="//field[@name='check_out']" position="after">
				<field name="checkout_store_id" readonly="is_store_readonly"/>
			</xpath>

			<xpath expr="(//separator)[1]" position="attributes">
			    <attribute name="invisible">1</attribute>
			</xpath>
			<xpath expr="//form//sheet//group//group[@name='check_in_group']" position="attributes">
				<attribute name="invisible">1</attribute>
			</xpath>

			<xpath expr="(//separator)[2]" position="attributes">
			    <attribute name="invisible">1</attribute>
			</xpath>
			<xpath expr="//form//sheet//group//group[@name='check_out_group']" position="attributes">
				<attribute name="invisible">1</attribute>
			</xpath>
			
			<xpath expr="//field[@name='check_out']/ancestor::group[1]" position="after">
			    <group>
			        <field name="previous_check_in" readonly="1"/>
			        <field name="previous_check_out" readonly="1"/>
			        <field name="worked_hours" readonly="1" widget="float_time"/>
			        <field name="adjustment_difference" readonly="1" widget="float_time"/>
			        <field name="modified_by_user_id" readonly="1"/>
			    </group>
			</xpath>

			<!-- RM - 18 SEP [ADD] From view in 'oe_chatter' box add -->
			<!-- <xpath expr="//form//sheet" position="after"> -->
				<!-- <div class="oe_chatter">
					<field name="message_follower_ids" widget="mail_followers"/>
					<field name="message_ids" widget="mail_thread"/>
				</div> -->
				<!-- <chatter/> -->
			<!-- </xpath> -->
		</field>
	</record>

