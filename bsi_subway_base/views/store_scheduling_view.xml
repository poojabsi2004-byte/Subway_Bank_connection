    <record id="bsi_work_hours_form_view" model="ir.ui.view">
        <field name="name">bsi.work.hours.form</field>
        <field name="model">bsi.work.hours</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <span class="o_form_label mx-3">
                                <b>Starting Hours</b>
                            </span>
                            <div class="d-flex">
                                <field name="starting_hour"/>
                                <span class="o_form_label mx-3 "> </span>
                                <field name="time_type" nolabel='1'/>
                            </div>
                            <span class="o_form_label mx-3">
                                <b>Name</b>
                            </span>
                            <div class="d-flex">
                                <field name="name" nolabel="1" />
                            </div>
                        </group>
                        <group>
                            <span class="o_form_label mx-3">
                                <b>Ending Hours</b>
                            </span>
                            <div class="d-flex">
                                <field name="ending_hour"/>
                                <span class="o_form_label mx-3 "> </span>
                                <field name="new_time_type" nolabel='1'/>
                            </div>
                            <span class="o_form_label mx-3">
                                <b>Planned Hours</b>
                            </span>
                            <div class="d-flex">
                                <field name="planned_hours" nolabel="1" widget="float_time" />
                            </div>
                        </group>
                    </group>
                    <p colspan="4" style="color: red;">
                    <strong>Note :</strong> 24 Hours Time format is used.</p><br/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="bsi_work_hours_list_view" model="ir.ui.view">
