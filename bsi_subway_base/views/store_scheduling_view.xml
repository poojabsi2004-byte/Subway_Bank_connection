            </graph>
        </field>
    </record>

    <record id="bsi_store_scheduling_pivot_view" model="ir.ui.view">
        <field name="name">store.scheduling.pivot</field>
        <field name="model">store.scheduling</field>
        <field name="arch" type="xml">
            <pivot string="Store Scheduling" sample="1">
                <field name="store_id" type="row"/>
                <field name="net_sales" type="measure"/>
                <field name="food_cost" type="measure"/>
                <field name="allowed_percentage_food_cost" type="measure"/> 
                <field name="food_cost_in_percentage" type="measure"/>
                <field name="over_or_short_food_cost" type="measure"/>
                <field name="ytd_over_or_short_food_cost" type="measure"/>
                <field name="allowed_scheduling_hours" type="measure"/>
                <field name="total_scheduled_hours" type="measure"/>
                <field name="over_or_short_matrix_hours" type="measure"/>
                <field name="payroll_taxes" type="measure"/>
                <field name="paychex_total_debit" type="measure"/>  
            </pivot>
        </field>
    </record>

    <record id="bsi_store_scheduling_search_view" model="ir.ui.view">
        <field name="name">store.scheduling.search.view</field>
        <field name="model">store.scheduling</field>
        <field name="arch" type="xml">
            <search>
                <separator/>
                <filter name="unactive" string="Archived" domain="[('active','=',False)]"/>
                <filter name="fltr_current_month" string="Current Month" date="week_ending_date" default_period="month"/>
                <group expand="0" string="Group By">
                    <filter string="Store" name="group_by_store" context="{'group_by':'store_id'}"/>
                    <filter string="Store Year" name="group_by_year" context="{'group_by':'week_ending_date:year'}"/>
                    <filter string="Store Month" name="group_by_month" context="{'group_by':'week_ending_date:month'}"/>
                </group>

            </search>
        </field>
    </record>

    <record id="action_bsi_store_scheduling_views" model="ir.actions.act_window">
        <field name="name">Store Scheduling</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">store.scheduling</field>
        <field name="context">{
            'search_default_group_by_store': True,
            'search_default_group_by_year': True,
            'search_default_group_by_month': True,
            'search_default_fltr_current_month': True}</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <!-- <field name="view_id" ref="bsi_store_scheduling_list_view"/> -->
        <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'list', 'view_id': ref('bsi_subway_base.bsi_store_scheduling_list_view')}),
        (0, 0, {'view_mode': 'form', 'view_id': ref('bsi_subway_base.bsi_store_scheduling_form_view')})]"/>
    </record>

    <record id="action_bsi_store_district_manager_views" model="ir.actions.act_window">
        <field name="name">Scheduling Requests</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">store.scheduling</field>
        <field name="context">{}</field>
        <field name="domain">[('state','=','to_be_approve')]</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'list', 'view_id': ref('bsi_subway_base.bsi_store_scheduling_list_view')}),
        (0, 0, {'view_mode': 'form', 'view_id': ref('bsi_subway_base.bsi_store_scheduling_requests_form_view')})]"/>
    </record>

</odoo>
