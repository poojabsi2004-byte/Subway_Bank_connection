<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="bsi_res_config_settings_inherit_form_view" model="ir.ui.view">
        <field name="name">bsi.res.config.settings.inherit.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <div class="app_settings_block" string="SFTP Server Configuration">
                    <h2>SFTP Server Configuration</h2>

                    
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="sftp_username"/>
                                <field name="sftp_username"/>
                            </div>
                        </div>
                    
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="sftp_password"/>
                                <field name="sftp_password" password="True"/>
                            </div>
                        </div>
                    </div>

                </div>
            </xpath>
        </field>
    </record>

</odoo>
